/*
    VSCode configuration
*/
{
    /*
        Settings editing
    */
    "workbench.settings.editor": "json",
    "workbench.settings.openDefaultSettings": false,
    "workbench.settings.openDefaultKeybindings": false,
    /*
        Security
    */
    "security.workspace.trust.untrustedFiles": "newWindow",
    /*
        Theming
    */
    "window.autoDetectColorScheme": true,
    "workbench.preferredLightColorTheme": "Adwaita Light & colorful status bar",
    "workbench.preferredDarkColorTheme": "Adwaita Dark",
    "workbench.productIconTheme": "adwaita",
    "editor.fontFamily": "'Hack', 'monospace'",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "terminal.integrated.fontSize": 14,
    "C_Cpp.inactiveRegionOpacity": 0.3,
    "coverage-gutters.highlightdark": "rgba(42, 161, 152, 0.25)",
    "coverage-gutters.highlightlight": "rgba(42, 161, 152, 0.15)",
    "coverage-gutters.partialHighlightDark": "rgba(181, 137, 0, 0.25)",
    "coverage-gutters.partialHighlightLight": "rgba(181, 137, 0, 0.15)",
    "coverage-gutters.noHighlightDark": "rgba(220, 50, 47, 0.25)",
    "coverage-gutters.noHighlightLight": "rgba(220, 50, 47, 0.15)",
    "workbench.colorCustomizations": {
        "[Solarized Light]": {
            "terminal.ansiWhite": "#073642"
        }
    },
    /*
        Components UI
    */
    "window.titleBarStyle": "custom",
    "window.customTitleBarVisibility": "auto",
    "window.menuBarVisibility": "compact",
    "window.enableMenuBarMnemonics": false,
    "breadcrumbs.enabled": true,
    "breadcrumbs.filePath": "last",
    "workbench.list.horizontalScrolling": true,
    "terminal.integrated.cursorStyle": "line",
    "window.zoomLevel": 0.0,
    /*
        Editor UI
    */
    "editor.lineNumbers": "interval",
    "editor.minimap.enabled": false,
    "editor.renderLineHighlight": "all",
    "editor.renderWhitespace": "none",
    "editor.renderControlCharacters": true,
    "editor.rulers": [
        80,
        120
    ],
    "editor.guides.indentation": false,
    "editor.cursorStyle": "line",
    "editor.cursorWidth": 1,
    "editor.cursorBlinking": "expand",
    "editor.smoothScrolling": true,
    "debug.inlineValues": "on",
    "editor.colorDecorators": true,
    "dimmer.enabled": true,
    "dimmer.opacity": 70,
    "dimmer.delay": 50,
    /*
        Editor behaviors
    */
    "editor.tabSize": 4,
    "editor.autoIndent": "full",
    "editor.detectIndentation": true,
    "editor.comments.ignoreEmptyLines": false,
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "files.autoSave": "off",
    "files.autoSaveDelay": 60000,
    "files.encoding": "utf8",
    "files.autoGuessEncoding": false, // This feature is broken and should be disabled in a project settings file
    "editor.multiCursorModifier": "alt",
    "bookmarks.keepBookmarksOnLineDelete": true,
    "bookmarks.label.suggestion": "useWhenSelected",
    /*
        Explorer behaviors
    */
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    /*
        Workbench behaviors
    */
    "workbench.externalBrowser": "firefox-developer-edition",
    /*
        Suggestions
    */
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": false,
    },
    "editor.snippetSuggestions": "bottom",
    "editor.wordBasedSuggestions": "matchingDocuments",
    "editor.suggest.filterGraceful": true,
    "editor.suggestSelection": "recentlyUsedByPrefix",
    "editor.suggest.localityBonus": true,
    "editor.acceptSuggestionOnEnter": "smart",
    "editor.acceptSuggestionOnCommitCharacter": true,
    /*
        Spell checking
    */
    "languageToolLinter.serviceType": "external",
    "languageToolLinter.languageTool.motherTongue": "fr",
    "languageToolLinter.languageTool.language": "auto",
    "languageToolLinter.languageTool.preferredVariants": "en-US,fr-FR",
    "cSpell.enabled": true,
    "cSpell.language": "fr,en",
    "cSpell.checkVSCodeSystemFiles": false,
    "cSpell.checkOnlyEnabledFileTypes": false,
    "cSpell.enabledFileTypes": {
        "xonsh": true
    },
    "cSpell.ignoreRandomStrings": true,
    "cSpell.reportUnknownWords": false,
    "cSpell.caseSensitive": true,
    "cSpell.customDictionaries": {
        "personnel": {
            "name": "Personnel",
            "path": "~/.local/share/cspell/personnel.cspell",
            "scope": "user",
        },
        "technical-computing": {
            "name": "Informatique",
            "path": "~/.local/share/cspell/technical-computing.cspell",
            "scope": "user",
        },
        "computing-tools": {
            "name": "Outils informatiques",
            "path": "~/.local/share/cspell/computing-tools.cspell",
            "scope": "user",
        },
        "ignore": {
            "name": "Termes ignorés",
            "path": "~/.local/share/cspell/ignore.cspell",
            "scope": "user",
            "noSuggest": true
        }
    },
    /*
        Files associations
    */
    "files.associations": {
        /*
            Zsh
        */
        "**/.config/zsh/**/*": "shellscript",
        "**/.local/share/zsh/**/*": "shellscript",
        /*
            Configure template
        */
        "*.h.in": "c",
        "*.conf.in": "properties",
        "*.service.in": "systemd-unit-file",
        "*.xml.in": "xml",
        /*
            C/C++
        */
        "*.private.h": "c",
        "*.h": "c",
        ".c": "c",
        ".C": "cpp",
        "*.cpp": "cpp",
        /*
            GNU Build system (Autotools)
        */
        "config.site": "shellscript",
        /*
            SCons
        */
        "SConstruct": "python",
        "SConscript": "python",
        /*
            Clang
        */
        "*.clang-format": "yaml",
        /*
            PkgConfig
        */
        "*.pc": "shellscript",
        /*
            Python
        */
        "*.yapf": "ini",
        ".flake8": "ini",
        ".coveragerc": "ini",
        /*
            Configuration files
        */
        "**/.config/fontconfig/**/*": "xml",
        "**/.config/feh/*": "tsv",
        /*
            Git related files
        */
        "TAG_EDITMSG": "git-commit",
        /*
            JSON
        */
        "*.jtd": "json"
    },
    /*
        Hidden files
    */
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true
    },
    /*
        Files excluded from searching (inherit hidden files)
    */
    "search.exclude": {
        "**/node_modules": true,
        "**/bower_components": true
    },
    /*
        Files watching
    */
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true
    },
    /*
        Diff
    */
    "diffEditor.ignoreTrimWhitespace": false,
    /*
        Debugging
    */
    "debug.openDebug": "openOnSessionStart",
    "debug.internalConsoleOptions": "openOnSessionStart",
    "debug.toolBarLocation": "commandCenter",
    "debug.hideLauncherWhileDebugging": true,
    "debug.allowBreakpointsEverywhere": true,
    "debug.showBreakpointsInOverviewRuler": true,
    "debug.terminal.clearBeforeReusing": true,
    "debug.console.acceptSuggestionOnEnter": "on",
    "debug.closeReadonlyTabsOnEnd": true,
    "launch": {
        "configurations": [],
        "compounds": []
    },
    /*
        Terminal
    */
    "terminal.integrated.hideOnStartup": "whenEmpty",
    "terminal.integrated.showExitAlert": false,
    "terminal.integrated.drawBoldTextInBrightColors": true,
    "terminal.integrated.fontWeightBold": "normal",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyleInactive": "line",
    "terminal.integrated.scrollback": 10000,
    "terminal.external.linuxExec": "gnome-terminal",
    "terminal.integrated.env.linux": {
        "VISUAL": "code --wait"
    },
    /*
        Telemetry
    */
    "telemetry.telemetryLevel": "off",
    "telemetry.feedback.enabled": false,
    "workbench.enableExperiments": false,
    "workbench.settings.enableNaturalLanguageSearch": false,
    /*
        Git
    */
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.enableSmartCommit": false,
    "git.suggestSmartCommit": false,
    "git.inputValidation": true,
    "git.allowForcePush": true,
    "git.useForcePushWithLease": true,
    "git.confirmForcePush": true,
    "git.untrackedChanges": "separate",
    "git.autoRepositoryDetection": "subFolders",
    "gitlens.keymap": "alternate",
    "gitlens.hovers.currentLine.enabled": false,
    "gitlens.currentLine.enabled": false,
    "gitlens.codeLens.enabled": false,
    "gitlens.views.scm.grouped.views": {
        "commits": true,
        "branches": true,
        "remotes": true,
        "stashes": true,
        "tags": true,
        "worktrees": true,
        "contributors": true,
        "repositories": true,
        "searchAndCompare": false,
        "launchpad": true
    },
    "[git-commit]": {
        "editor.rulers": [
            50,
            72
        ]
    },
    /*
        Coverage
    */
    "coverage-gutters.coverageFileNames": [
        "lcov.info",
        "cov.xml",
        "jacoco.xml",
        "coverage.xml"
    ],
    "coverage-gutters.ignoredPathGlobs": "**/{node_modules,venv,vendor,tests}/**",
    "coverage-gutters.showGutterCoverage": false,
    "coverage-gutters.showRulerCoverage": false,
    "coverage-gutters.showLineCoverage": true,
    /*
        C/C++
    */
    "C_Cpp.clang_format_path": "/usr/bin/clang-format",
    "C_Cpp.clang_format_style": "file",
    "C_Cpp.clang_format_fallbackStyle": "Visual Studio",
    "C_Cpp.default.configurationProvider": "vector-of-bool.cmake-tools",
    /*
        CMake
    */
    "cmake.preferredGenerators": [
        "Unix Makefiles",
        "Ninja",
    ],
    "cmake.configureOnOpen": true,
    "cmake.autoRestartBuild": true,
    "cmake.revealLog": "never",
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.installPrefix": "${workspaceFolder}/build/install",
    "cmake.enabledOutputParsers": [
        "cmake",
        "gcc",
        "gnuld",
    ],
    "[cmake]": {
        "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?"
    },
    /*
        Python
    */
    "python.languageServer": "Pylance",
    "python.venvPath": "~/.cache/pypoetry/virtualenvs",
    "black-formatter.args": [
        "--line-length",
        "79",
    ],
    "isort.args": [
        "--profile",
        "black",
    ],
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        "--spec"
    ],
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        },
        "editor.guides.indentation": true,
        "editor.rulers": [
            79
        ]
    },
    "kivy.requireKivyHeader": true,
    "[kivy]": {
        "editor.guides.indentation": true,
    },
    /*
        Shell script
    */
    "shellcheck.customArgs": [
        "-x"
    ],
    "shellcheck.exclude": [
        "SC1071", // Ignore error about unsupported Zsh
    ],
    "shellformat.path": "/usr/bin/shfmt",
    "shellformat.flag": "-s -bn -ci",
    "shellformat.effectLanguages": [
        "shellscript",
        "dockerfile",
        "dotenv",
        "hosts",
        "jvmoptions",
        "ignore",
        "gitignore",
        "properties",
        "spring-boot-properties",
        "azcli",
        "bats"
    ],
    "[shellscript]": {
        "editor.tabSize": 2,
    },
    "bashIde.highlightParsingErrors": true,
    /*
        XML
    */
    "xml.format.splitAttributes": false,
    /*
        JSON
    */
    "json.schemas": [
        {
            "fileMatch": [
                "**/*.webmanifest"
            ],
            "url": "https://json.schemastore.org/web-manifest-combined.json"
        }
    ],
    /*
        Javascript
    */
    "javascript.inlayHints.variableTypes.enabled": true,
    "javascript.inlayHints.enumMemberValues.enabled": true,
    "typescript.inlayHints.propertyDeclarationTypes.enabled": true,
    "javascript.inlayHints.functionLikeReturnTypes.enabled": true,
    "typescript.inlayHints.parameterTypes.enabled": true,
    "javascript.inlayHints.parameterNames.enabled": "all",
    "javascript.updateImportsOnFileMove.enabled": "prompt",
    "javascript.format.semicolons": "insert",
    "javascript.referencesCodeLens.showOnAllFunctions": true,
    "javascript.suggest.completeFunctionCalls": true,
    "javascript.preferences.importModuleSpecifier": "relative",
    "javascript.preferences.importModuleSpecifierEnding": "js",
    "debug.javascript.unmapMissingSources": true,
    "javascript.format.enable": false,
    "[javascript]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "never",
            "source.organizeImports": "explicit",
        },
    },
    /*
        LaTeX
    */
    "latex-workshop.latex.autoBuild.run": "onSave",
    "latex-workshop.latex.autoBuild.cleanAndRetry.enabled": true,
    "latex-workshop.latex.recipe.default": "tectonic",
    "latex-workshop.formatting.latex": "tex-fmt",
    "latex-workshop.intellisense.package.enabled": true,
    "latex-workshop.intellisense.package.unusual": true,
    /*
        Typst
    */
    "tinymist.lint.enabled": true,
    "tinymist.formatterMode": "disable",
    "tinymist.exportPdf": "never",
    "tinymist.renderDocs": "disable",
    "[typst]": {
        "editor.wordWrap": "off",
    },
    /*
        Other languages
    */
    "[tsv]": {
        "editor.insertSpaces": false,
    },
    /*
        Custom commands
    */
    "settings.cycle": [
        {
            "id": "lineNumbers",
            "values": [
                {
                    "editor.lineNumbers": "interval"
                },
                {
                    "editor.lineNumbers": "relative"
                }
            ]
        }
    ],
}
