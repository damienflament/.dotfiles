# Sélection des fichiers de configuration personnelle à versionner. #

# On commence par ignorer tous les fichiers, à l'exception de celui-ci et de la
# licence.
/*
!/.gitignore
!/.LICENSE

# Ensuite, on ajoute les fichiers désirés.
#
# Afin de continuer à ignorer tous les fichiers par défaut, l'ajout d'un
# dossier doit s'accompagner d'une règle pour ignorer tous les fichiers qu'il
# contient.

# Todo
!/TODO.md

# Répertoires principaux
!/.config/
/.config/*

!/.local/
/.local/*

!/.local/etc    # .local/etc --> .config

!/.local/scripts/

!/.local/share/
/.local/share/*

# Fichiers de données
!/.local/share/dircolors/
!/.local/share/setcolors/

# Zsh
!/.config/zsh/
!/.local/share/zsh/

# Xonsh
!/.config/xonsh
!/.local/share/xonsh/
/.local/share/xonsh/*
!/.local/share/xonsh/site-packages/

# Systemd
!/.config/systemd/
/.config/systemd/*
!/.config/systemd/user/

# Gestion de paquets
!/.config/pacman/

# Polices de caractères
!/.config/fontconfig/
/.config/fontconfig/fonts.conf

# Gestion de version
!/.config/git/

# Code
!/.config/Code - OSS/
/.config/Code - OSS/*

!/.config/Code - OSS/User/
/.config/Code - OSS/User/*

!/.config/Code - OSS/User/keybindings.json
!/.config/Code - OSS/User/settings.json
!/.config/Code - OSS/User/snippets

# C
!/.config/autotools/

# PHP
!/.config/composer/
/.config/composer/*
!/.config/composer/composer.json

# Python
__pycache__/
*.pyc
!/.config/python/
!/.config/pypoetry/

# Haskell
!/.config/cabal/

!/.config/stack/
/.config/stack/*
!/.config/stack/config.yaml

# XMonad
!/.xmonad/
/.xmonad/*
/.xmonad/**/*.hs

# Serveur X
!/.config/X/

# Utilitaires
!/.config/dialog/
!/.config/feh/
!/.config/htop/
!/.config/vim/

# vim: ft=gitconfig
