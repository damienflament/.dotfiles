#! /usr/bin/env xonsh
"""
Usage: archive <directory>

Archive un répertoire.

Arguments:
    <directory>     Le répertoire à archiver.

Options:
    -h --help       Affiche cette aide.
"""

from datetime import datetime

from my.scripting import docopt, check_available, exit_error, STATUS


args = docopt(__doc__)
directory = pf"{args['<directory>']}"

check_available("tar")

if not directory.exists():
    exit_error(f"le répertoire {directory} n'existe pas.", STATUS.NO_INPUT)

if not directory.is_dir():
    exit_error(f"{directory} n'est pas un répertoire.", STATUS.DATA_ERR)

now = datetime.now()
destination = f"{directory}-{now:%Y%m%d-%H%M%S}.tar.xz"


tar --create  --file @(destination) --xz @(directory)

print(destination)
