{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug tests",
            "type": "debugpy",
            "request": "launch",
            "program": "${file} foo",
            "purpose": [
                "debug-test"
            ],
            "env": {
                // Permet d'utiliser les breakpoints lorsque pytest-cov est installé
                "PYTEST_ADDOPTS": "--no-cov",
            },
            "justMyCode": false
        },
    ]
}
