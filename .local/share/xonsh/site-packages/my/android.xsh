""" Périphériques Android. """

from .command import check_available
from .error import Error


class Device:
    """ Un périphérique Android. """

    transport_id: int
    serial: str
    state: str
    usb_address: str
    product_id: str
    model: str
    codename: str

def get_devices() -> list[Device]:
    """ Fournit la liste des périphériques Android connectés. """

    check_available("adb")

    adb start-server

    return []
