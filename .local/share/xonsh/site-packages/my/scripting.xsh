""" Utilitaires pour l'écriture de scripts. """

from sys import exit, stderr

class Status:
    """ Code de status d'un programme lors qu'il quitte.

    Status génériques:
        success         Succès
        failure         Erreur générique

    Status disponibles pour l'utilisateur: de 2 à 63

    Status pour les programmes:
        usage           Mauvaise utilisation de la commande
        data_err        Mauvais format de données en entrée
        no_input        Pas de données en entrée (fichier introuvable)
        no_user         Utilisateur introuvable
        no_host         Hôte introuvable
        unavailable     Service indisponible
        software_err    Erreur logicielle (hors OS)
        os_err          Erreur du système d'exploitation
        os_file_err     Erreur dans un fichier du système d'exploitation
        cant_create     Impossible de créer le fichier de sortie
        io_err          Erreur d'entrée/sortie
        temp_fail       Erreur temporaire, réessayez
        protocol_err    Non respect du protocole
        no_perm         Pas de permission pour l'opération demandée
        config_err      Erreur de configuration

    Status pour les scripts:
        not_found       Commande introuvable

    Status lorsque le programme reçoit un signal:
        sig_hup     Hangup                      Connexion interrompue (terminal fermé)
        sig_int     Interrupt                   Programme interrompu par Ctrl-C
        sig_quit    Quit                        Sortie du programme par Ctrl-D
        sig_ill     Illegal                     Instruction illégale
        sig_trap    Trap                        Point d'arrêt pour débuggage
        sig_abrt    Abort                       Fin anormale du programme
        sig_bus     Bus                         Erreur de bus de données
        sig_fpe     Floating Point Exception    Opération mathématique illégale
        sig_kill    Killed                      Terminaison forcée du programme
        sig_usr1    User 1                      Signal utilisateur 1
        sig_segv    Segmentation Fault          Erreur de segmentation mémoire
        sig_usr2    User 2                      Signal utilisateur 2
        sig_pipe    Pipe                        Pipe interrompu
        sig_alrm    Alarm                       Alarme utilisateur expirée
        sig_term    Terminated                  Terminaison du processus
        sig_stkflt  Stack Fault                 Erreur de pile du coprocesseur
        sig_chld    Child                       Arrêt ou fin du processus fils
        sig_cont    Continue                    Reprise du processus
        sig_stop    Stop                        Mise en pause du processus
        sig_tstp    Terminal Stop               Mise en pause du processus depuis le terminal par Ctrl-Z
        sig_ttin    TTY Input                   Le processus en arrière plan veut lire depuis le terminal
        sig_ttou    TTY Output                  Le processus en arrière plan veut écrire dans le terminal
        sig_urg     Urgent                      Données urgentes à lire sur le socket
        sig_xcpu    Exceed CPU                  Dépassement de la limite d'utilisation du CPU
        sig_xfsz    Exceed File Size            Dépassement de la limite de taille d'un fichier
        sig_vtalrm  Virtual Timer Alarm         Alarme virtuelle expirée
        sig_prof    Profiling                   Minuteur du profilage expiré
        sig_winch   Window Change               Redimensionnement de la fenêtre
        sig_io      Input/Output                Entrée/sortie disponible
        sig_pwr     Power                       Problème d'alimentation / redémarrage
        sig_sys     System                      Mauvais appel système
    """

    # Status génériques:
    success = 0
    failure = 1

    # Status pour les programmes systèmes:
    # cf. `man sysexits.h`
    usage = 64
    data_err = 65
    no_input = 66
    no_user = 67
    no_host = 68
    unavailable = 69
    software_err = 70
    os_err = 71
    os_file_err = 72
    cant_create = 73
    io_err = 74
    temp_fail = 75
    protocol_err = 76
    no_perm = 77
    config_err = 78

    # Status pour les scripts:
    # cf. le manuel Bash https://tldp.org/LDP/abs/html/exitcodes.html
    not_found = 127

    # Status lors de la réception d'un signal:
    # Le manuel Bash définie un code de status 128 à partir duquel est ajouté
    # le numéro du signal
    sig_hup = 129
    sig_int = 130
    sig_quit = 131
    sig_ill = 132
    sig_trap = 133
    sig_abrt = 134
    sig_bus = 135
    sig_fpe = 136
    sig_kill = 137
    sig_usr1 = 138
    sig_segv = 139
    sig_usr2 = 140
    sig_pipe = 141
    sig_alrm = 142
    sig_term = 143
    sig_stkflt = 144
    sig_chld = 145
    sig_cont = 146
    sig_stop = 147
    sig_tstp = 148
    sig_ttin = 149
    sig_ttou = 150
    sig_urg = 151
    sig_xcpu = 152
    sig_xfsz = 153
    sig_vtalrm = 154
    sig_prof = 155
    sig_winch = 156
    sig_io = 157
    sig_pwr = 158
    sig_sys = 159

def error(message: str, status: int = Status.failure):
    """ Affiche le message sur la sortie d'erreur et quitte le programme avec le
        status spécifié.
    """
    print(f"erreur: {message}", file=stderr)
    exit(status)
