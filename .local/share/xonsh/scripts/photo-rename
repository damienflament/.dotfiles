#! /usr/bin/env xonsh
"""
Usage: photo-rename <file> [<file>...]

Renomme des photos.

Arguments:
    <file>      Les fichiers à renommer.

Options:
    -h --help   Affiche cette aide.
"""

from my.scripting import docopt, check_available, exit_error, STATUS, ErrorManager

args = docopt(__doc__)
filenames = args["<file>"]

check_available("exiftool")

em = ErrorManager()

def fix_suffix(suffix: str) -> str:
    """Corrige l'extension de fichier."""
    match suffix:
        case ".JPG" | ".jpeg" | ".JPEG":
            return ".jpg"
        case _:
            return suffix

for f in filenames:
    f = pf"{f}"

    if not f.exists():
        em.error(f"le fichier {f} n'existe pas", STATUS.NO_INPUT)
        continue

    # Extraction de la date et de l'heure depuis le fichier
    try:
        stem = $(exiftool -s3 -d "%Y-%m-%d_%H-%M-%S" -CreateDate @(f))
    except Exception:
        em.error(f"impossible de lire les métadonnées de la photo {f}", STATUS.SOFTWARE_ERR)
        continue

    # Gestion d'une date vide
    if (len(stem) == 0):
        em.error(f"impossible de lire la date de la photo {f}", STATUS.SOFTWARE_ERR)
        continue

    target = f.with_stem(stem).with_suffix(fix_suffix(f.suffix))

    # Prévention d'un écrasement de fichier
    if target.exists() and f != target:
        em.error(f"le fichier {target} existe déjà", STATUS.CANT_CREATE)
        continue

    # Rien n'est fait si le fichier est déjà bien nommé
    if (target == f):
        continue

    # Renommage
    print(f"{f} -> {target}")
    f.rename(target)

em.exit()
